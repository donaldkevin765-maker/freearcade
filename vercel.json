{
  "name": "freearcade",
  "version": 2,
  "public": true,
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin-allow-popups" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    }
  ],
  "redirects": [
    { "source": "/netlify.toml", "destination": "/", "permanent": true },
    { "source": "/deploy.sh", "destination": "/", "permanent": true }
  ]
}
